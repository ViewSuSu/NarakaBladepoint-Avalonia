<base:UserControlBase
    x:Class="NarakaBladepoint.Modules.CommonFunction.UI.SkillPoint.Views.SkillPointPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:attach="clr-namespace:NarakaBladepoint.Framework.UI.AttachedProperties;assembly=NarakaBladepoint.Framework"
    xmlns:base="clr-namespace:NarakaBladepoint.Framework.Core.Bases.Views;assembly=NarakaBladepoint.Framework"
    xmlns:controls="clr-namespace:NarakaBladepoint.Controls;assembly=NarakaBladepoint.Controls"
    xmlns:converters="clr-namespace:NarakaBladepoint.Modules.CommonFunction.UI.SkillPoint.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fwConverters="clr-namespace:NarakaBladepoint.Framework.UI.Converters;assembly=NarakaBladepoint.Framework"
    xmlns:local="clr-namespace:NarakaBladepoint.Modules.CommonFunction.UI.SkillPoint.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:skillControls="clr-namespace:NarakaBladepoint.Modules.CommonFunction.UI.SkillPoint.Controls"
    xmlns:skillViews="clr-namespace:NarakaBladepoint.Modules.CommonFunction.UI.SkillPoint.Views"
    xmlns:system="clr-namespace:System;assembly=System.Runtime"
    xmlns:viewmodels="clr-namespace:NarakaBladepoint.Modules.CommonFunction.UI.SkillPoint.ViewModels"
    d:DesignHeight="720"
    d:DesignWidth="1280"
    xmlns:i="using:Avalonia.Xaml.Interactivity"
    xmlns:ia="using:Avalonia.Xaml.Interactions.Core"
    mc:Ignorable="d">
    <base:UserControlBase.Resources>
        <converters:HorizontalMirrorConverter x:Key="HorizontalMirrorConverter" />
        <converters:VerticalMirrorConverter x:Key="VerticalMirrorConverter" />
        <converters:CenterOffsetConverter x:Key="CenterOffsetConverter" />
        <converters:PolarToCartesianConverter x:Key="PolarToCartesianConverter" />
        <converters:UpperLeftPolarConverter x:Key="UpperLeftPolarConverter" />
        <converters:LearnedToOpacityConverter x:Key="LearnedToOpacityConverter" />
        <converters:DependencySkillPointConverter x:Key="DependencySkillPointConverter" />
        <converters:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter" />
        <converters:SelectedSkillVisibilityConverter x:Key="SelectedSkillVisibilityConverter" />
        <converters:CanEditImageVisibilityConverter x:Key="CanEditImageVisibilityConverter" />
        <fwConverters:ImageSourceToFileNameConverter x:Key="ImageSourceToFileNameConverter" />

        <system:Double x:Key="FirstCircleSkillPointSize">40</system:Double>
        <system:Double x:Key="SecondCircleSkillPointSize">50</system:Double>
        <system:Double x:Key="ThirdCircleSkillPointSize">60</system:Double>
        <system:Double x:Key="SkillPointElementSize">0</system:Double>
        <system:Double x:Key="CanEditIconSize">10</system:Double>
        <system:Double x:Key="TenOClockAngle">110</system:Double>
        <system:Double x:Key="ElevenOClockAngle">145</system:Double>
        <system:Double x:Key="FirstCircleRadius">100</system:Double>
        <system:Double x:Key="SecondCircleRadius">180</system:Double>
        <system:Double x:Key="ThirdCircleRadius">260</system:Double>

        <Thickness x:Key="FirstCircleTextBlockMargin">0,0,0,0</Thickness>
        <Thickness x:Key="SecondCircleTextBlockMargin">0,0,0,0</Thickness>
        <Thickness x:Key="ThirdCircleTextBlockMargin">0,0,0,0</Thickness>

        <!--  Tags Collections (defined as comma-separated strings, parsed in code-behind)  -->
        <system:String x:Key="F1Tags">受击可用,防御</system:String>
        <system:String x:Key="F2Tags">伤害,控制</system:String>
        <system:String x:Key="V1Tags">机动,伤害,续命</system:String>
        <system:String x:Key="V2Tags">机动,伤害,续命,充能</system:String>

        <!--  Talent Item Grid Style  -->
        

        <!--  Style for Skill Point Grid with Triggers  -->
        
    </base:UserControlBase.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="0.85*" />
        </Grid.ColumnDefinitions>
        <Grid.Background>
            <ImageBrush Source="{StaticResource SkillPointBackgroundImage}" />
        </Grid.Background>
        <Grid Grid.Column="0" Margin="40,50,0,50">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.3*" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Background="{StaticResource DefaultTransientBlackBackground8}">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.5*" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Image
                    Name="hero"
                    HorizontalAlignment="Left"
                    Source="{StaticResource ZhangQiLingHeroImage}" />
                <StackPanel
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center">
                    <TextBlock
                        Name="heroName"
                        VerticalAlignment="Center"
                        FontSize="25"
                        Text="{Binding ElementName=hero, Path=Source, Converter={StaticResource ImageSourceToFileNameConverter}}" />
                    <TextBlock
                        Margin="0,10,0,0"
                        VerticalAlignment="Center"
                        FontSize="15"
                        Text="切换角色" />
                </StackPanel>
            </Grid>
            <UniformGrid Grid.Row="1" Rows="3">
                <skillControls:SelectiveBorder x:Name="boder1" Background="{StaticResource DefaultTransientBlackBackground3}">
                    <Grid>
                        <TextBlock Margin="30" Text="天赋" />
                        <UniformGrid
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Columns="3">
                            <skillControls:TalentGrid
                                x:Name="tianfu1"
                                Width="40"
                                Height="40"
                                IsSelected="True">
                                    <i:Interaction.Behaviors>
                                        <ia:EventTriggerBehavior EventName="SelectionChanged">
                                            <ia:ChangePropertyAction
                                                PropertyName="CurrentSelectedTianfu"
                                                TargetObject="{Binding RelativeSource={RelativeSource AncestorType=base:UserControlBase}, Path=DataContext}"
                                                Value="tianfu1" />
                                        </ia:EventTriggerBehavior>
                                    </i:Interaction.Behaviors>
                                <Viewbox
                                    Width="10"
                                    Height="9"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    ZIndex="1"
                                    Stretch="Fill"
                                    StretchDirection="Both">
                                    <RadioButton
                                        Foreground="Gray"
                                        GroupName="1"
                                        IsChecked="{Binding RelativeSource={RelativeSource AncestorType=skillControls:TalentGrid}, Path=IsSelected}"
                                        IsVisible="{Binding RelativeSource={RelativeSource AncestorType=skillControls:TalentGrid}, Path=IsSelected}" />
                                </Viewbox>
                                <Image Source="{StaticResource TianFu1Image}" />
                            </skillControls:TalentGrid>

                            <skillControls:TalentGrid
                                x:Name="tianfu2"
                                Width="40"
                                Height="40"
                                Margin="5,0">
                                    <i:Interaction.Behaviors>
                                        <ia:EventTriggerBehavior EventName="SelectionChanged">
                                            <ia:ChangePropertyAction
                                                PropertyName="CurrentSelectedTianfu"
                                                TargetObject="{Binding RelativeSource={RelativeSource AncestorType=base:UserControlBase}, Path=DataContext}"
                                                Value="tianfu2" />
                                        </ia:EventTriggerBehavior>
                                    </i:Interaction.Behaviors>
                                <Viewbox
                                    Width="10"
                                    Height="9"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    ZIndex="1"
                                    Stretch="Fill"
                                    StretchDirection="Both">
                                    <RadioButton
                                        Foreground="Gray"
                                        GroupName="1"
                                        IsChecked="{Binding RelativeSource={RelativeSource AncestorType=skillControls:TalentGrid}, Path=IsSelected}"
                                        IsVisible="{Binding RelativeSource={RelativeSource AncestorType=skillControls:TalentGrid}, Path=IsSelected}" />
                                </Viewbox>
                                <Image Source="{StaticResource TianFu2Image}" />
                            </skillControls:TalentGrid>

                            <skillControls:TalentGrid
                                x:Name="tianfu3"
                                Width="40"
                                Height="40">
                                    <i:Interaction.Behaviors>
                                        <ia:EventTriggerBehavior EventName="SelectionChanged">
                                            <ia:ChangePropertyAction
                                                PropertyName="CurrentSelectedTianfu"
                                                TargetObject="{Binding RelativeSource={RelativeSource AncestorType=base:UserControlBase}, Path=DataContext}"
                                                Value="tianfu3" />
                                        </ia:EventTriggerBehavior>
                                    </i:Interaction.Behaviors>
                                <Viewbox
                                    Width="10"
                                    Height="9"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    ZIndex="1"
                                    Stretch="Fill"
                                    StretchDirection="Both">
                                    <RadioButton
                                        Foreground="Gray"
                                        GroupName="1"
                                        IsChecked="{Binding RelativeSource={RelativeSource AncestorType=skillControls:TalentGrid}, Path=IsSelected}"
                                        IsVisible="{Binding RelativeSource={RelativeSource AncestorType=skillControls:TalentGrid}, Path=IsSelected}" />
                                </Viewbox>
                                <Image Source="{StaticResource TianFu2Image}" />
                            </skillControls:TalentGrid>
                        </UniformGrid>
                    </Grid>
                </skillControls:SelectiveBorder>

                <skillControls:SelectiveBorder
                    x:Name="boder2"
                    Margin="0,5"
                    Background="{StaticResource DefaultTransientBlackBackground3}">
                    <Grid>
                        <TextBlock Margin="30" Text="技能" />
                        <UniformGrid
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Columns="2">
                            <skillControls:TalentGrid
                                x:Name="f1"
                                Width="40"
                                Height="40"
                                IsSelected="False">
                                    <i:Interaction.Behaviors>
                                        <ia:EventTriggerBehavior EventName="SelectionChanged">
                                            <ia:ChangePropertyAction
                                                PropertyName="CurrentSelectedSkillType"
                                                TargetObject="{Binding RelativeSource={RelativeSource AncestorType=base:UserControlBase}, Path=DataContext}"
                                                Value="f1" />
                                        </ia:EventTriggerBehavior>
                                    </i:Interaction.Behaviors>
                                <Viewbox
                                    Width="10"
                                    Height="9"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    ZIndex="1"
                                    Stretch="Fill"
                                    StretchDirection="Both">
                                    <RadioButton
                                        Foreground="Gray"
                                        GroupName="FSkillSelection"
                                        IsChecked="{Binding RelativeSource={RelativeSource AncestorType=skillControls:TalentGrid}, Path=IsSelected}"
                                        IsVisible="{Binding RelativeSource={RelativeSource AncestorType=skillControls:TalentGrid}, Path=IsSelected}" />
                                </Viewbox>
                                <Image Source="{StaticResource F1Image}" />
                            </skillControls:TalentGrid>

                            <skillControls:TalentGrid
                                x:Name="f2"
                                Width="40"
                                Height="40"
                                Margin="5,0">
                                    <i:Interaction.Behaviors>
                                        <ia:EventTriggerBehavior EventName="SelectionChanged">
                                            <ia:ChangePropertyAction
                                                PropertyName="CurrentSelectedSkillType"
                                                TargetObject="{Binding RelativeSource={RelativeSource AncestorType=base:UserControlBase}, Path=DataContext}"
                                                Value="f2" />
                                        </ia:EventTriggerBehavior>
                                    </i:Interaction.Behaviors>
                                <Viewbox
                                    Width="10"
                                    Height="9"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    ZIndex="1"
                                    Stretch="Fill"
                                    StretchDirection="Both">
                                    <RadioButton
                                        Foreground="Gray"
                                        GroupName="FSkillSelection"
                                        IsChecked="{Binding RelativeSource={RelativeSource AncestorType=skillControls:TalentGrid}, Path=IsSelected}"
                                        IsVisible="{Binding RelativeSource={RelativeSource AncestorType=skillControls:TalentGrid}, Path=IsSelected}" />
                                </Viewbox>
                                <Image Source="{StaticResource F2Image}" />
                            </skillControls:TalentGrid>
                        </UniformGrid>
                    </Grid>
                </skillControls:SelectiveBorder>
                <skillControls:SelectiveBorder x:Name="boder3" Background="{StaticResource DefaultTransientBlackBackground3}">
                    <Grid>
                        <TextBlock Margin="30" Text="奥义" />
                        <UniformGrid
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Columns="2">
                            <skillControls:TalentGrid
                                x:Name="v1"
                                Width="40"
                                Height="40"
                                IsSelected="False">
                                    <i:Interaction.Behaviors>
                                        <ia:EventTriggerBehavior EventName="SelectionChanged">
                                            <ia:ChangePropertyAction
                                                PropertyName="CurrentSelectedSkillType"
                                                TargetObject="{Binding RelativeSource={RelativeSource AncestorType=base:UserControlBase}, Path=DataContext}"
                                                Value="v1" />
                                        </ia:EventTriggerBehavior>
                                    </i:Interaction.Behaviors>
                                <Viewbox
                                    Width="10"
                                    Height="9"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    ZIndex="1"
                                    Stretch="Fill"
                                    StretchDirection="Both">
                                    <RadioButton
                                        Foreground="Gray"
                                        GroupName="VSkillSelection"
                                        IsChecked="{Binding RelativeSource={RelativeSource AncestorType=skillControls:TalentGrid}, Path=IsSelected}"
                                        IsVisible="{Binding RelativeSource={RelativeSource AncestorType=skillControls:TalentGrid}, Path=IsSelected}" />
                                </Viewbox>
                                <Image Source="{StaticResource V1Image}" />
                            </skillControls:TalentGrid>

                            <skillControls:TalentGrid
                                x:Name="v2"
                                Width="40"
                                Height="40"
                                Margin="5,0">
                                    <i:Interaction.Behaviors>
                                        <ia:EventTriggerBehavior EventName="SelectionChanged">
                                            <ia:ChangePropertyAction
                                                PropertyName="CurrentSelectedSkillType"
                                                TargetObject="{Binding RelativeSource={RelativeSource AncestorType=base:UserControlBase}, Path=DataContext}"
                                                Value="v2" />
                                        </ia:EventTriggerBehavior>
                                    </i:Interaction.Behaviors>
                                <Viewbox
                                    Width="10"
                                    Height="9"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    ZIndex="1"
                                    Stretch="Fill"
                                    StretchDirection="Both">
                                    <RadioButton
                                        Foreground="Gray"
                                        GroupName="VSkillSelection"
                                        IsChecked="{Binding RelativeSource={RelativeSource AncestorType=skillControls:TalentGrid}, Path=IsSelected}"
                                        IsVisible="{Binding RelativeSource={RelativeSource AncestorType=skillControls:TalentGrid}, Path=IsSelected}" />
                                </Viewbox>
                                <Image Source="{StaticResource V2Image}" />
                            </skillControls:TalentGrid>
                        </UniformGrid>
                    </Grid>
                </skillControls:SelectiveBorder>
            </UniformGrid>
        </Grid>
        <Grid Name="mainGrid" Grid.Column="1">
            <Canvas x:Name="skillPointCanvas" ClipToBounds="False">
                <Canvas.IsVisible>
                    <MultiBinding Converter="{StaticResource SelectedSkillVisibilityConverter}" ConverterParameter="canvas">
                        <Binding Path="CurrentSelectedSkillType" />
                    </MultiBinding>
                </Canvas.IsVisible>
                <Ellipse
                    x:Name="ellipse"
                    Canvas.Left="{Binding ElementName=skillPointCanvas, Path=Bounds.Width, Converter={StaticResource CenterOffsetConverter}, ConverterParameter=80}"
                    Canvas.Top="{Binding ElementName=skillPointCanvas, Path=Bounds.Height, Converter={StaticResource CenterOffsetConverter}, ConverterParameter=80}"
                    Width="80"
                    Height="80"
                    Fill="{StaticResource DefaultTransientBlackBackground3}"
                    Stroke="{StaticResource DefaultOrangeBrush}"
                    StrokeThickness="3" />
                <StackPanel
                    x:Name="stackPanel"
                    Canvas.Left="{Binding ElementName=ellipse, Path=(Canvas.Left)}"
                    Canvas.Top="{Binding ElementName=ellipse, Path=(Canvas.Top)}"
                    Width="80"
                    Margin="0,15,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    ZIndex="1">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="24"
                        Foreground="White"
                        Text="{Binding RemainingPoints}" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="10"
                        Text="剩余点数" />
                </StackPanel>

                <!--  LeftUp Circle 1 - 10 O'Clock  -->
                <Grid
                    x:Name="LuGrid"
                    Width="{StaticResource FirstCircleSkillPointSize}"
                    Height="{StaticResource FirstCircleSkillPointSize}"
                    Tag="{Binding SkillPointsLeftDown[0]}">
                        <i:Interaction.Behaviors>
                            <ia:EventTriggerBehavior EventName="PointerPressed">
                                <ia:InvokeCommandAction Command="{Binding LearnSkillCommand}" CommandParameter="{Binding SkillPointsLeftDown[0]}" />
                            </ia:EventTriggerBehavior>
                            <ia:EventTriggerBehavior EventName="PointerPressed">
                                <ia:InvokeCommandAction Command="{Binding UnlearnSkillCommand}" CommandParameter="{Binding SkillPointsLeftDown[0]}" />
                            </ia:EventTriggerBehavior>
                        </i:Interaction.Behaviors>
                    <Canvas.Left>
                        <Binding
                            Converter="{StaticResource UpperLeftPolarConverter}"
                            ConverterParameter="{converters:SkillPointParameter Radius={StaticResource FirstCircleRadius},
                                                                                Angle={StaticResource TenOClockAngle},
                                                                                ElementSize={StaticResource SkillPointElementSize},
                                                                                Coordinate=0}"
                            ElementName="ellipse"
                            Path="(Canvas.Left)" />
                    </Canvas.Left>
                    <Canvas.Top>
                        <Binding
                            Converter="{StaticResource UpperLeftPolarConverter}"
                            ConverterParameter="{converters:SkillPointParameter Radius={StaticResource FirstCircleRadius},
                                                                                Angle={StaticResource TenOClockAngle},
                                                                                ElementSize={StaticResource SkillPointElementSize},
                                                                                Coordinate=1}"
                            ElementName="ellipse"
                            Path="(Canvas.Top)" />
                    </Canvas.Top>
                    <Image Source="{StaticResource SkillPointLeftDownFirstCircle1Image}" />
                    <Image
                        Width="{StaticResource CanEditIconSize}"
                        Height="{StaticResource CanEditIconSize}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        ZIndex="1"
                        Source="{StaticResource CanEditImage}">
                        <Image.IsVisible>
                            <MultiBinding Converter="{StaticResource CanEditImageVisibilityConverter}">
                                <Binding Path="SkillPointsLeftDown[0].IsLearnable" />
                                <Binding Path="RemainingPoints" />
                            </MultiBinding>
                        </Image.IsVisible>
                    </Image>
                    <TextBlock
                        Margin="{StaticResource FirstCircleTextBlockMargin}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        ZIndex="1">
                        <Run FontSize="10" Text="{Binding SkillPointsLeftDown[0].CurrentLearned}" />
                        <Run FontSize="10" Text="/" />
                        <Run FontSize="10" Text="4" />
                    </TextBlock>
                </Grid>

                <!--  LeftUp Circle 1 - 11 O'Clock  -->
                <Grid
                    x:Name="MaGrid"
                    Width="{StaticResource FirstCircleSkillPointSize}"
                    Height="{StaticResource FirstCircleSkillPointSize}"
                    Tag="{Binding SkillPointsLeftDown[1]}">
                        <i:Interaction.Behaviors>
                            <ia:EventTriggerBehavior EventName="PointerPressed">
                                <ia:InvokeCommandAction Command="{Binding LearnSkillCommand}" CommandParameter="{Binding SkillPointsLeftDown[1]}" />
                            </ia:EventTriggerBehavior>
                            <ia:EventTriggerBehavior EventName="PointerPressed">
                                <ia:InvokeCommandAction Command="{Binding UnlearnSkillCommand}" CommandParameter="{Binding SkillPointsLeftDown[1]}" />
                            </ia:EventTriggerBehavior>
                        </i:Interaction.Behaviors>
                    <Canvas.Left>
                        <Binding
                            Converter="{StaticResource UpperLeftPolarConverter}"
                            ConverterParameter="{converters:SkillPointParameter Radius={StaticResource FirstCircleRadius},
                                                                                Angle={StaticResource ElevenOClockAngle},
                                                                                ElementSize={StaticResource SkillPointElementSize},
                                                                                Coordinate=0}"
                            ElementName="ellipse"
                            Path="(Canvas.Left)" />
                    </Canvas.Left>
                    <Canvas.Top>
                        <Binding
                            Converter="{StaticResource UpperLeftPolarConverter}"
                            ConverterParameter="{converters:SkillPointParameter Radius={StaticResource FirstCircleRadius},
                                                                                Angle={StaticResource ElevenOClockAngle},
                                                                                ElementSize={StaticResource SkillPointElementSize},
                                                                                Coordinate=1}"
                            ElementName="ellipse"
                            Path="(Canvas.Top)" />
                    </Canvas.Top>
                    <Image Source="{StaticResource SkillPointLeftDownFirstCircle2Image}" />
                    <Image
                        Width="{StaticResource CanEditIconSize}"
                        Height="{StaticResource CanEditIconSize}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        ZIndex="1"
                        Source="{StaticResource CanEditImage}">
                        <Image.IsVisible>
                            <MultiBinding Converter="{StaticResource CanEditImageVisibilityConverter}">
                                <Binding Path="SkillPointsLeftDown[1].IsLearnable" />
                                <Binding Path="RemainingPoints" />
                            </MultiBinding>
                        </Image.IsVisible>
                    </Image>
                    <TextBlock
                        Margin="{StaticResource FirstCircleTextBlockMargin}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        ZIndex="1">
                        <Run FontSize="10" Text="{Binding SkillPointsLeftDown[1].CurrentLearned}" />
                        <Run FontSize="10" Text="/" />
                        <Run FontSize="10" Text="4" />
                    </TextBlock>
                </Grid>

                <!--  LeftUp Circle 2 - 10 O'Clock  -->
                <Grid
                    x:Name="HeGrid"
                    Width="{StaticResource SecondCircleSkillPointSize}"
                    Height="{StaticResource SecondCircleSkillPointSize}"
                    Tag="{Binding SkillPointsLeftDown[2]}">
                        <i:Interaction.Behaviors>
                            <ia:EventTriggerBehavior EventName="PointerPressed">
                                <ia:InvokeCommandAction Command="{Binding LearnSkillCommand}" CommandParameter="{Binding SkillPointsLeftDown[2]}" />
                            </ia:EventTriggerBehavior>
                            <ia:EventTriggerBehavior EventName="PointerPressed">
                                <ia:InvokeCommandAction Command="{Binding UnlearnSkillCommand}" CommandParameter="{Binding SkillPointsLeftDown[2]}" />
                            </ia:EventTriggerBehavior>
                        </i:Interaction.Behaviors>
                    <Grid.IsEnabled>
                        <MultiBinding Converter="{StaticResource DependencySkillPointConverter}" FallbackValue="True">
                            <Binding Path="SkillPointsLeftDown[0].CurrentLearned" />
                            <Binding Path="SkillPointsLeftDown[1].CurrentLearned" />
                            <Binding Path="SkillPointsLeftDown[0].TotalLearnable" />
                        </MultiBinding>
                    </Grid.IsEnabled>
                    <Canvas.Left>
                        <Binding
                            Converter="{StaticResource UpperLeftPolarConverter}"
                            ConverterParameter="{converters:SkillPointParameter Radius={StaticResource SecondCircleRadius},
                                                                                Angle={StaticResource TenOClockAngle},
                                                                                ElementSize={StaticResource SkillPointElementSize},
                                                                                Coordinate=0}"
                            ElementName="ellipse"
                            Path="(Canvas.Left)" />
                    </Canvas.Left>
                    <Canvas.Top>
                        <Binding
                            Converter="{StaticResource UpperLeftPolarConverter}"
                            ConverterParameter="{converters:SkillPointParameter Radius={StaticResource SecondCircleRadius},
                                                                                Angle={StaticResource TenOClockAngle},
                                                                                ElementSize={StaticResource SkillPointElementSize},
                                                                                Coordinate=1}"
                            ElementName="ellipse"
                            Path="(Canvas.Top)" />
                    </Canvas.Top>
                    <Image Source="{StaticResource SkillPointLeftDownFirstCircle1Image}" />
                    <Image
                        Width="{StaticResource CanEditIconSize}"
                        Height="{StaticResource CanEditIconSize}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        ZIndex="1"
                        Source="{StaticResource CanEditImage}">
                        <Image.IsVisible>
                            <MultiBinding Converter="{StaticResource CanEditImageVisibilityConverter}">
                                <Binding Path="SkillPointsLeftDown[2].IsLearnable" />
                                <Binding Path="RemainingPoints" />
                            </MultiBinding>
                        </Image.IsVisible>
                    </Image>
                    <TextBlock
                        Margin="{StaticResource SecondCircleTextBlockMargin}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        ZIndex="1">
                        <Run FontSize="10" Text="{Binding SkillPointsLeftDown[2].CurrentLearned}" />
                        <Run FontSize="10" Text="/" />
                        <Run FontSize="10" Text="4" />
                    </TextBlock>
                </Grid>

                <!--  LeftUp Circle 2 - 11 O'Clock  -->
                <Grid
                    x:Name="OuGrid"
                    Width="{StaticResource SecondCircleSkillPointSize}"
                    Height="{StaticResource SecondCircleSkillPointSize}"
                    Tag="{Binding SkillPointsLeftDown[3]}">
                        <i:Interaction.Behaviors>
                            <ia:EventTriggerBehavior EventName="PointerPressed">
                                <ia:InvokeCommandAction Command="{Binding LearnSkillCommand}" CommandParameter="{Binding SkillPointsLeftDown[3]}" />
                            </ia:EventTriggerBehavior>
                            <ia:EventTriggerBehavior EventName="PointerPressed">
                                <ia:InvokeCommandAction Command="{Binding UnlearnSkillCommand}" CommandParameter="{Binding SkillPointsLeftDown[3]}" />
                            </ia:EventTriggerBehavior>
                        </i:Interaction.Behaviors>
                    <Grid.IsEnabled>
                        <MultiBinding Converter="{StaticResource DependencySkillPointConverter}" FallbackValue="True">
                            <Binding Path="SkillPointsLeftDown[0].CurrentLearned" />
                            <Binding Path="SkillPointsLeftDown[1].CurrentLearned" />
                            <Binding Path="SkillPointsLeftDown[0].TotalLearnable" />
                        </MultiBinding>
                    </Grid.IsEnabled>
                    <Canvas.Left>
                        <Binding
                            Converter="{StaticResource UpperLeftPolarConverter}"
                            ConverterParameter="{converters:SkillPointParameter Radius={StaticResource SecondCircleRadius},
                                                                                Angle={StaticResource ElevenOClockAngle},
                                                                                ElementSize={StaticResource SkillPointElementSize},
                                                                                Coordinate=0}"
                            ElementName="ellipse"
                            Path="(Canvas.Left)" />
                    </Canvas.Left>
                    <Canvas.Top>
                        <Binding
                            Converter="{StaticResource UpperLeftPolarConverter}"
                            ConverterParameter="{converters:SkillPointParameter Radius={StaticResource SecondCircleRadius},
                                                                                Angle={StaticResource ElevenOClockAngle},
                                                                                ElementSize={StaticResource SkillPointElementSize},
                                                                                Coordinate=1}"
                            ElementName="ellipse"
                            Path="(Canvas.Top)" />
                    </Canvas.Top>
                    <Image Source="{StaticResource SkillPointLeftDownSecondCircle2Image}" />
                    <Image
                        Width="{StaticResource CanEditIconSize}"
                        Height="{StaticResource CanEditIconSize}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        ZIndex="1"
                        Source="{StaticResource CanEditImage}">
                        <Image.IsVisible>
                            <MultiBinding Converter="{StaticResource CanEditImageVisibilityConverter}">
