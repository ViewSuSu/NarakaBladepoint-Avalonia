                        <i:Interaction.Behaviors>
                            <ia:EventTriggerBehavior EventName="PointerPressed">
                                <ia:InvokeCommandAction Command="{Binding LearnSkillCommand}" CommandParameter="{Binding SkillPointsLeftUp[4]}" />
                            </ia:EventTriggerBehavior>
                            <ia:EventTriggerBehavior EventName="PointerPressed">
                                <ia:InvokeCommandAction Command="{Binding UnlearnSkillCommand}" CommandParameter="{Binding SkillPointsLeftUp[4]}" />
                            </ia:EventTriggerBehavior>
                        </i:Interaction.Behaviors>
                    <Grid.IsEnabled>
                        <MultiBinding Converter="{StaticResource DependencySkillPointConverter}">
                            <Binding Path="SkillPointsLeftUp[2].CurrentLearned" />
                            <Binding Path="SkillPointsLeftUp[3].CurrentLearned" />
                            <Binding Path="SkillPointsLeftUp[2].TotalLearnable" />
