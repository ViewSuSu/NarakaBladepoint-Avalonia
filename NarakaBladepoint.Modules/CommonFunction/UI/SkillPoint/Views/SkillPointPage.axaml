                    </Grid.IsEnabled>
                    <Canvas.Left>
                        <MultiBinding Converter="{StaticResource HorizontalMirrorConverter}" ConverterParameter="50">
                            <Binding ElementName="HeGrid" Path="(Canvas.Left)" />
                            <Binding ElementName="skillPointCanvas" Path="Bounds.Width" />
                        </MultiBinding>
                    </Canvas.Left>
                    <Canvas.Top>
                        <MultiBinding Converter="{StaticResource VerticalMirrorConverter}" ConverterParameter="50">
                            <Binding ElementName="HeGrid" Path="(Canvas.Top)" />
                            <Binding ElementName="skillPointCanvas" Path="Bounds.Height" />
                        </MultiBinding>
                    </Canvas.Top>
                    <Image Source="{StaticResource SkillPointRightUpSecondCircle2Image}" />
                    <Image
                        Width="{StaticResource CanEditIconSize}"
                        Height="{StaticResource CanEditIconSize}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        ZIndex="1"
                        Source="{StaticResource CanEditImage}"
                        IsVisible="{Binding SkillPointsRightUp[2].IsLearnable}" />
                    <TextBlock
                        Margin="{StaticResource SecondCircleTextBlockMargin}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        ZIndex="1">
                        <Run FontSize="10" Text="{Binding SkillPointsRightUp[2].CurrentLearned}" />
                        <Run FontSize="10" Text="/" />
                        <Run FontSize="10" Text="4" />
                    </TextBlock>
                </Grid>

                <Grid
                    Width="{StaticResource SecondCircleSkillPointSize}"
                    Height="{StaticResource SecondCircleSkillPointSize}"
                    Tag="{Binding SkillPointsRightUp[3]}">
                        <i:Interaction.Behaviors>
                            <ia:EventTriggerBehavior EventName="PointerPressed">
                                <ia:InvokeCommandAction Command="{Binding LearnSkillCommand}" CommandParameter="{Binding SkillPointsRightUp[3]}" />
                            </ia:EventTriggerBehavior>
                            <ia:EventTriggerBehavior EventName="PointerPressed">
                                <ia:InvokeCommandAction Command="{Binding UnlearnSkillCommand}" CommandParameter="{Binding SkillPointsRightUp[3]}" />
                            </ia:EventTriggerBehavior>
                        </i:Interaction.Behaviors>
                    <Grid.IsEnabled>
                        <MultiBinding Converter="{StaticResource DependencySkillPointConverter}">
                            <Binding Path="SkillPointsRightUp[0].CurrentLearned" />
                            <Binding Path="SkillPointsRightUp[1].CurrentLearned" />
                            <Binding Path="SkillPointsRightUp[0].TotalLearnable" />
                        </MultiBinding>
                    </Grid.IsEnabled>
                    <Canvas.Left>
                        <MultiBinding Converter="{StaticResource HorizontalMirrorConverter}" ConverterParameter="50">
                            <Binding ElementName="OuGrid" Path="(Canvas.Left)" />
                            <Binding ElementName="skillPointCanvas" Path="Bounds.Width" />
                        </MultiBinding>
                    </Canvas.Left>
                    <Canvas.Top>
                        <MultiBinding Converter="{StaticResource VerticalMirrorConverter}" ConverterParameter="50">
                            <Binding ElementName="OuGrid" Path="(Canvas.Top)" />
                            <Binding ElementName="skillPointCanvas" Path="Bounds.Height" />
                        </MultiBinding>
                    </Canvas.Top>
                    <Image Source="{StaticResource SkillPointRightUpSecondCircle1Image}" />
                    <Image
                        Width="{StaticResource CanEditIconSize}"
                        Height="{StaticResource CanEditIconSize}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        ZIndex="1"
                        Source="{StaticResource CanEditImage}"
                        IsVisible="{Binding SkillPointsRightUp[3].IsLearnable}" />
                    <TextBlock
                        Margin="{StaticResource SecondCircleTextBlockMargin}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        ZIndex="1">
                        <Run FontSize="10" Text="{Binding SkillPointsRightUp[3].CurrentLearned}" />
                        <Run FontSize="10" Text="/" />
                        <Run FontSize="10" Text="4" />
                    </TextBlock>
                </Grid>

                <Grid
                    Width="{StaticResource ThirdCircleSkillPointSize}"
                    Height="{StaticResource ThirdCircleSkillPointSize}"
                    Tag="{Binding SkillPointsRightUp[4]}">
                        <i:Interaction.Behaviors>
                            <ia:EventTriggerBehavior EventName="PointerPressed">
                                <ia:InvokeCommandAction Command="{Binding LearnSkillCommand}" CommandParameter="{Binding SkillPointsRightUp[4]}" />
                            </ia:EventTriggerBehavior>
                            <ia:EventTriggerBehavior EventName="PointerPressed">
                                <ia:InvokeCommandAction Command="{Binding UnlearnSkillCommand}" CommandParameter="{Binding SkillPointsRightUp[4]}" />
                            </ia:EventTriggerBehavior>
                        </i:Interaction.Behaviors>
                    <Grid.IsEnabled>
                        <MultiBinding Converter="{StaticResource DependencySkillPointConverter}">
                            <Binding Path="SkillPointsRightUp[2].CurrentLearned" />
                            <Binding Path="SkillPointsRightUp[3].CurrentLearned" />
                            <Binding Path="SkillPointsRightUp[2].TotalLearnable" />
                        </MultiBinding>
                    </Grid.IsEnabled>
                    <Canvas.Left>
                        <MultiBinding Converter="{StaticResource HorizontalMirrorConverter}" ConverterParameter="50">
                            <Binding ElementName="XiongGrid" Path="(Canvas.Left)" />
                            <Binding ElementName="skillPointCanvas" Path="Bounds.Width" />
                        </MultiBinding>
                    </Canvas.Left>
                    <Canvas.Top>
                        <MultiBinding Converter="{StaticResource VerticalMirrorConverter}" ConverterParameter="50">
                            <Binding ElementName="XiongGrid" Path="(Canvas.Top)" />
                            <Binding ElementName="skillPointCanvas" Path="Bounds.Height" />
                        </MultiBinding>
                    </Canvas.Top>
                    <Image Source="{StaticResource SkillPointRightUpThirdCircle1Image}" />
                    <Image
                        Width="{StaticResource CanEditIconSize}"
                        Height="{StaticResource CanEditIconSize}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        ZIndex="1"
                        Source="{StaticResource CanEditImage}"
                        IsVisible="{Binding SkillPointsRightUp[4].IsLearnable}" />
                    <TextBlock
                        Margin="{StaticResource ThirdCircleTextBlockMargin}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        ZIndex="1">
                        <Run FontSize="10" Text="{Binding SkillPointsRightUp[4].CurrentLearned}" />
                        <Run FontSize="10" Text="/" />
                        <Run FontSize="10" Text="2" />
                    </TextBlock>
                </Grid>

                <Grid
                    Width="{StaticResource ThirdCircleSkillPointSize}"
                    Height="{StaticResource ThirdCircleSkillPointSize}"
                    Tag="{Binding SkillPointsRightUp[5]}">
                        <i:Interaction.Behaviors>
                            <ia:EventTriggerBehavior EventName="PointerPressed">
                                <ia:InvokeCommandAction Command="{Binding LearnSkillCommand}" CommandParameter="{Binding SkillPointsRightUp[5]}" />
                            </ia:EventTriggerBehavior>
                            <ia:EventTriggerBehavior EventName="PointerPressed">
                                <ia:InvokeCommandAction Command="{Binding UnlearnSkillCommand}" CommandParameter="{Binding SkillPointsRightUp[5]}" />
                            </ia:EventTriggerBehavior>
                        </i:Interaction.Behaviors>
                    <Grid.IsEnabled>
                        <MultiBinding Converter="{StaticResource DependencySkillPointConverter}">
                            <Binding Path="SkillPointsRightUp[2].CurrentLearned" />
                            <Binding Path="SkillPointsRightUp[3].CurrentLearned" />
                            <Binding Path="SkillPointsRightUp[2].TotalLearnable" />
                        </MultiBinding>
                    </Grid.IsEnabled>
                    <Canvas.Left>
                        <MultiBinding Converter="{StaticResource HorizontalMirrorConverter}" ConverterParameter="50">
                            <Binding ElementName="ShiGrid" Path="(Canvas.Left)" />
                            <Binding ElementName="skillPointCanvas" Path="Bounds.Width" />
                        </MultiBinding>
                    </Canvas.Left>
                    <Canvas.Top>
                        <MultiBinding Converter="{StaticResource VerticalMirrorConverter}" ConverterParameter="50">
                            <Binding ElementName="ShiGrid" Path="(Canvas.Top)" />
                            <Binding ElementName="skillPointCanvas" Path="Bounds.Height" />
                        </MultiBinding>
                    </Canvas.Top>
                    <Image Source="{StaticResource SkillPointRightUpThirdCircle2Image}" />
                    <Image
                        Width="{StaticResource CanEditIconSize}"
                        Height="{StaticResource CanEditIconSize}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        ZIndex="1"
                        Source="{StaticResource CanEditImage}"
                        IsVisible="{Binding SkillPointsRightUp[5].IsLearnable}" />
                    <TextBlock
                        Margin="{StaticResource ThirdCircleTextBlockMargin}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        ZIndex="1">
                        <Run FontSize="10" Text="{Binding SkillPointsRightUp[5].CurrentLearned}" />
                        <Run FontSize="10" Text="/" />
                        <Run FontSize="10" Text="2" />
                    </TextBlock>
                </Grid>
            </Canvas>

            <!--  SkillFPage - 显示技能详情  -->
            <skillViews:SkillDescriptionPage
                x:Name="skillFPage"
                Title="发丘指"
                Margin="10,50"
                DescriptionHeight="100"
                TagHeight="20"
                TagWidth="80"
                Tags="{StaticResource F1Tags}"
                VideoSource="{Binding F1VideoSource}">
                <skillViews:SkillDescriptionPage.IsVisible>
                    <MultiBinding Converter="{StaticResource SelectedSkillVisibilityConverter}" ConverterParameter="f1">
                        <Binding Path="CurrentSelectedSkillType" />
                    </MultiBinding>
                </skillViews:SkillDescriptionPage.IsVisible>
                <skillViews:SkillDescriptionPage.Description>
                    <TextBlock
                        Padding="10"
                        VerticalAlignment="Center"
                        attach:TextBlockHighlightAttachedProperty.HighlightForeground="{StaticResource DefaultOrangeBrush}"
                        attach:TextBlockHighlightAttachedProperty.HighlightText="受击中可用。"
                        FontSize="12"
                        Foreground="#FFFFFF"
                        Text="向前方突进并击飞敌人后，进入1.2秒【拨挡】架势。&#10;• 【拨挡】架势期间不可移动，自身受到攻击可自动触发反击。&#10;• 受击中可用。"
                        TextWrapping="Wrap" />
                </skillViews:SkillDescriptionPage.Description>
            </skillViews:SkillDescriptionPage>

            <!--  SkillFPage - F2技能详情  -->
            <skillViews:SkillDescriptionPage
                x:Name="f2SkillFPage"
                Title="发丘指·锁喉"
                Margin="10,50"
                DescriptionHeight="100"
                TagHeight="20"
                TagWidth="80"
                Tags="{StaticResource F2Tags}"
                VideoSource="{Binding F2VideoSource}">
                <skillViews:SkillDescriptionPage.IsVisible>
                    <MultiBinding Converter="{StaticResource SelectedSkillVisibilityConverter}" ConverterParameter="f2">
                        <Binding Path="CurrentSelectedSkillType" />
                    </MultiBinding>
                </skillViews:SkillDescriptionPage.IsVisible>
                <skillViews:SkillDescriptionPage.Description>
                    <TextBlock
                        Padding="10"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="#FFFFFF"
                        TextWrapping="Wrap">
                        <Run Text="凝聚指力，向前方突进戳刺，命中时根据敌人的霸体状态产生不同效果：" />
                        <LineBreak />
                        <Run Text="• 若命中非霸体敌人，则" />
                        <Run Foreground="{StaticResource DefaultOrangeBrush}" Text="锁喉控制敌人2秒，" />
                        <Run Text="且" />
                        <Run Foreground="{StaticResource DefaultOrangeBrush}" Text="可再按" />
                        <InlineUIContainer>
                            <Image
                                Width="10"
                                Height="10"
                                Margin="2,0"
                                VerticalAlignment="Center"
                                Source="{StaticResource SkillPointFKeyImage}" />
                        </InlineUIContainer>
                        <Run Foreground="{StaticResource DefaultOrangeBrush}" Text="将其击飞" />
                        <Run Text="。" />
                        <LineBreak />
                        <Run Text="• 若命中蓝霸体、紫霸体、金霸体状态下的敌人，则直接将其击飞。" />
                        <LineBreak />
                        <Run Text="• 奥义状态下，若命中非霸体、蓝霸体、紫霸体状态下的敌人，则触发特殊处决招式。" />
                    </TextBlock>
                </skillViews:SkillDescriptionPage.Description>
            </skillViews:SkillDescriptionPage>

            <!--  V1技能详情 - 麒麟怒  -->
            <skillViews:SkillDescriptionPage
                x:Name="v1SkillDescriptionPage"
                Title="麒麟怒"
                Margin="10,50"
                DescriptionHeight="100"
                TagHeight="20"
                TagWidth="80"
                Tags="{StaticResource V1Tags}"
                VideoSource="{Binding V1VideoSource}">
                <skillViews:SkillDescriptionPage.IsVisible>
                    <MultiBinding Converter="{StaticResource SelectedSkillVisibilityConverter}" ConverterParameter="v1">
                        <Binding Path="CurrentSelectedSkillType" />
                    </MultiBinding>
                </skillViews:SkillDescriptionPage.IsVisible>
                <skillViews:SkillDescriptionPage.Description>
                    <TextBlock
                        Padding="10"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="#FFFFFF"
                        TextWrapping="Wrap">
                        <Run Text="张起灵以麒麟血淬炼古刀，击退周围敌人并替换武器为【黑金古刀】，持续22秒；" />
                        <LineBreak />
                        <Run Text="期间可发动5次斩击" />
                        <LineBreak />
                        <LineBreak />
                        <InlineUIContainer>
                            <Image
                                Width="10"
                                Height="10"
                                Margin="2,0"
                                VerticalAlignment="Center"
                                Source="{StaticResource MouseLeftButtonImage}" />
                        </InlineUIContainer>
                        <Run Text="或" />
                        <InlineUIContainer>
                            <Image
                                Width="10"
                                Height="10"
                                Margin="2,0"
                                VerticalAlignment="Center"
                                Source="{StaticResource MouseRightButtonImage}" />
                        </InlineUIContainer>
                        <Run Text="获得全新的普通攻击及蓄力招式，并消耗斩击次数。" />
                        <LineBreak />
                        <Run Text="·蓄力跑动期间不会被非霸体招式和飞索打断。" />
                        <LineBreak />
                        <Run Text="·奥义期间，斩击次数耗尽或体力不足400时，触发" />
                        <Run Foreground="{StaticResource DefaultOrangeBrush}" Text="【宝血护命】" />
                        <Run Text="。" />
                        <LineBreak />
                        <Run Text="·【宝血护命】：4秒内自身体力不会低于400，" />
                        <Run Foreground="{StaticResource DefaultOrangeBrush}" Text="且期间可无消耗使用斩击" />
                        <Run Text="。" />
                        <LineBreak />
                        <Run Text="·若斩击次数耗尽，且当前不处于【宝血护命】状态时，则奥义提前结束。" />
                        <LineBreak />
                        <Run Text="·触发【宝血护命】时，" />
                        <Run Foreground="{StaticResource DefaultOrangeBrush}" Text="若自身处于被控制或受击状态" />
                        <Run Text="，则会击退周围敌人。" />
                    </TextBlock>
                </skillViews:SkillDescriptionPage.Description>
            </skillViews:SkillDescriptionPage>

            <!--  V2技能详情  -->
            <skillViews:SkillDescriptionPage
                x:Name="v2SkillDescriptionPage"
                Title="麒麟怒・绝斩"
                Margin="10,50"
                DescriptionHeight="100"
                TagHeight="20"
                TagWidth="80"
                Tags="{StaticResource V2Tags}"
                VideoSource="{Binding V2VideoSource}">
                <skillViews:SkillDescriptionPage.IsVisible>
                    <MultiBinding Converter="{StaticResource SelectedSkillVisibilityConverter}" ConverterParameter="v2">
                        <Binding Path="CurrentSelectedSkillType" />
                    </MultiBinding>
                </skillViews:SkillDescriptionPage.IsVisible>
                <skillViews:SkillDescriptionPage.Description>
                    <TextBlock
                        Padding="10"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="#FFFFFF"
                        TextWrapping="Wrap">
                        <Run Text="张起灵以麒麟血淬炼古刀，击退周围敌人并替换武器为【黑金古刀】，持续22秒；" />
                        <LineBreak />
                        <Run Text="期间可发动2次斩击。" />
                        <LineBreak />
                        <Run Text="·普通攻击与蓄力招式【怒意绝斩】均会消耗斩击次数，若次数耗尽则可消耗体力" />
                        <LineBreak />
                        <Run Foreground="{StaticResource DefaultOrangeBrush}" Text="额外发动斩击，命中敌人时根据命中人数回复体力，蓄力招式可以被振刀架势抵挡" />
                        <LineBreak />
                        <Run Text="·蓄力跑动期间不会被非霸体招式和飞索打断。" />
                        <LineBreak />
                        <Run Text="·奥义期间若体力不足300时触发【宝血护命】。" />
                        <LineBreak />
                        <Run Text="·若斩击次数耗尽且体力低于200，则奥义提前结束。" />
                        <LineBreak />
                        <Run Text="·【宝血护命】：4秒内自身体力不会低于300" />
                        <Run Foreground="{StaticResource DefaultOrangeBrush}" Text="且期间内可无消耗使用斩击" />
                        <Run Text="。" />
                        <LineBreak />
                        <Run Text="·【怒意绝斩】：向准星方向高速冲刺斩击，短时间后出现记忆灵体，灵体会沿冲刺轨迹再次发动斩击。" />
                        <LineBreak />
                        <Run Text="·触发【宝血护命】时，" />
                        <Run Foreground="{StaticResource DefaultOrangeBrush}" Text="若自身处于被控制或受击状态" />
                        <Run Text="，则会击退周围敌人。" />
                    </TextBlock>
                </skillViews:SkillDescriptionPage.Description>
            </skillViews:SkillDescriptionPage>
        </Grid>
        <Grid Grid.Column="2">
            <UniformGrid
                Height="30"
                Margin="0,0,0,50"
                VerticalAlignment="Bottom"
                Columns="2"
                IsVisible="{Binding ElementName=boder1, Path=IsHighlighted}">
                <Button
                    Margin="10,0"
                    Command="{Binding AutoAssignCommand}"
                    Content="自动装配" />
                <Button
                    Margin="10,0"
                    Command="{Binding ResetAllCommand}"
                    Content="全部重置" />
            </UniformGrid>
        </Grid>
        <controls:EscBackControl
            Grid.Column="2"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Command="{Binding ReturnToHallCommand}" />
    </Grid>

</base:UserControlBase>
