                        <Run FontSize="10" Text="/" />
                        <Run FontSize="10" Text="4" />
                    </TextBlock>
                </Grid>

                <Grid
                    Width="{StaticResource SecondCircleSkillPointSize}"
                    Height="{StaticResource SecondCircleSkillPointSize}"
                    Tag="{Binding SkillPointsRightUp[2]}">
                        <i:Interaction.Behaviors>
                            <ia:EventTriggerBehavior EventName="PointerPressed">
                                <ia:InvokeCommandAction Command="{Binding LearnSkillCommand}" CommandParameter="{Binding SkillPointsRightUp[2]}" />
                            </ia:EventTriggerBehavior>
                            <ia:EventTriggerBehavior EventName="PointerPressed">
                                <ia:InvokeCommandAction Command="{Binding UnlearnSkillCommand}" CommandParameter="{Binding SkillPointsRightUp[2]}" />
                            </ia:EventTriggerBehavior>
                        </i:Interaction.Behaviors>
                    <Grid.IsEnabled>
