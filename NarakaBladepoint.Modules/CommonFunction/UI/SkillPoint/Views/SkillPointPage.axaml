                        VerticalAlignment="Bottom"
                        ZIndex="1">
                        <Run FontSize="10" Text="{Binding SkillPointsLeftUp[4].CurrentLearned}" />
                        <Run FontSize="10" Text="/" />
                        <Run FontSize="10" Text="2" />
                    </TextBlock>
                </Grid>

                <Grid
                    Width="{StaticResource FirstCircleSkillPointSize}"
                    Height="{StaticResource FirstCircleSkillPointSize}"
