<UserControl
    x:Class="NarakaBladepoint.Modules.CommonFunction.UI.Inventory.Views.InventoryMainContentPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:attach="clr-namespace:NarakaBladepoint.Framework.UI.AttachedProperties;assembly=NarakaBladepoint.Framework"
    xmlns:controls="clr-namespace:NarakaBladepoint.Controls;assembly=NarakaBladepoint.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:NarakaBladepoint.Modules.CommonFunction.UI.Inventory.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:NarakaBladepoint.Modules.CommonFunction.UI.Inventory.ViewModels"
    d:DesignHeight="720"
    d:DesignWidth="1280"
    mc:Ignorable="d">
    <Grid Background="{StaticResource Background2}">
        <Grid>
            <TabControl
                attach:TabControlContentMarginAttachedProperty.IsAutoAdjustContentMargin="True"
                Background="Transparent"
                BorderThickness="0">
                <TabItem
                    Width="550"
                    Height="25"
                    Header=""
                    IsVisible="False" />
                <TabItem
                    Width="50"
                    Height="25"
                    Background="{StaticResource DefaultTransientBlackBackground5}"
                    Header="道具"
                    IsSelected="True">
                    <local:InventoryPage Margin="15" />
                </TabItem>
                <TabItem
                    Width="80"
                    Height="25"
                    Background="{StaticResource DefaultTransientBlackBackground5}"
                    Header="谪星外观">
                    <local:InventoryPageThree Margin="15" />
                </TabItem>
                <TabItem
                    Width="80"
                    Height="25"
                    Background="{StaticResource DefaultTransientBlackBackground5}"
                    Header="可交易道具">
                    <local:InventoryPageTwo Margin="15" />
                </TabItem>
            </TabControl>
        </Grid>
        <controls:EscBackControl
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            ZIndex="5"
            Command="{Binding ReturnToHallCommand}" />
    </Grid>
</UserControl>
