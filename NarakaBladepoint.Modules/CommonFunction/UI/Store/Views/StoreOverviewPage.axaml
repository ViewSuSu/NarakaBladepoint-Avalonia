<views:UserControlBase
    x:Class="NarakaBladepoint.Modules.CommonFunction.UI.Store.Views.StoreOverviewPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:NarakaBladepoint.Controls;assembly=NarakaBladepoint.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:NarakaBladepoint.Modules.CommonFunction.UI.Store.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:NarakaBladepoint.Modules.CommonFunction.UI.Store.ViewModels"
    xmlns:views="clr-namespace:NarakaBladepoint.Framework.Core.Bases.Views;assembly=NarakaBladepoint.Framework"
    d:DesignHeight="720"
    d:DesignWidth="1280"
    mc:Ignorable="d">
    <Grid>
        <Grid Margin="50,30,50,120">
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Text="未拥有 "/>
                <CheckBox
                    Margin="5,0,0,0" />
                <controls:ToggleButtonComboBox
                    Width="200"
                    Height="30"
                    Margin="0,0,15,0"
                    ItemsSource="{Binding SortList}"
                    SelectedIndex="{Binding SelectedSortIndex}" />
            </StackPanel>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.3*" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel
                    Margin="10,5"
                    VerticalAlignment="Top"
                    Orientation="Vertical">
                    <controls:ToggleButtonComboBox
                        Height="30"
                        Name="combobox1"
                        ItemsSource="{Binding QualityList}"
                        SelectedIndex="{Binding SelectedQualityIndex}" />
                    <controls:ToggleButtonComboBox
                        Height="30"
                        Margin="0,10,0,0"
                        ItemsSource="{Binding CategoryList}"
                        SelectedIndex="{Binding SelectedCategoryIndex}" />
                </StackPanel>

                <ItemsControl Grid.Column="1" ItemsSource="{Binding OverviewImages}">
                    <ItemsControl.Template>
                        <ControlTemplate TargetType="ItemsControl">
                            <ScrollViewer Padding="{TemplateBinding Padding}">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </ControlTemplate>
                    </ItemsControl.Template>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="5" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:HighlightBorder
                                Margin="5"
                                Background="Gray"
                                EnableMaskOnHover="True">
                                <Image Source="{Binding}" Stretch="UniformToFill" />
                            </controls:HighlightBorder>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Grid>
    </Grid>
</views:UserControlBase>
