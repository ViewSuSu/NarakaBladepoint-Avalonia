<bases:UserControlBase
x:Class="NarakaBladepoint.Modules.StartGame.UI.HeroChose.Views.HeroChosePage"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:bases="clr-namespace:NarakaBladepoint.Framework.Core.Bases.Views;assembly=NarakaBladepoint.Framework"
xmlns:controls="clr-namespace:NarakaBladepoint.Controls;assembly=NarakaBladepoint.Controls"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:local="clr-namespace:NarakaBladepoint.Modules.StartGame.UI.HeroChose.Views"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:viewmodels="clr-namespace:NarakaBladepoint.Modules.StartGame.UI.HeroChose.ViewModels"
    d:DesignHeight="720"
    d:DesignWidth="1280"
    xmlns:i="using:Avalonia.Xaml.Interactivity"
    xmlns:ia="using:Avalonia.Xaml.Interactions.Core"
    mc:Ignorable="d">
    <Grid Background="#E6000000">
        <Grid Margin="80,30,80,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.25*" />
                <RowDefinition />
                <RowDefinition Height="0.1*" />
            </Grid.RowDefinitions>
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Vertical">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="36"
                    Foreground="White"
                    Text="预选英雄 "/>
                <TextBlock
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="White"
                    Text="请选择3个英雄，匹配时会优先按照首选英雄进行匹配队友。若未选择英雄，则代表任意英雄" />
            </StackPanel>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.5*" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <ItemsControl
                    Grid.Column="0"
                    IsEnabled="{Binding IsCanSelcted, Mode=OneWay}"
                    ItemsSource="{Binding HeroChoseModuleItemModels}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="5">
                                <Border
                                    ZIndex="1"
                                    BorderBrush="White"
                                    BorderThickness="1"
                                    IsVisible="{Binding IsSelected}" />
                                <Image
                                    Source="{Binding HeroAvatarModel.Avatar, Mode=OneWay}"
                                    Stretch="Uniform" />
                                <Rectangle
                                    Fill="#E6000000"
                                    Opacity="0.5"
                                    IsVisible="{Binding IsSelected, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                <Image
                                    Width="10"
                                    Height="10"
                                    Margin="5"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    ZIndex="1"
                                    Source="{StaticResource ModeSelectionIcon6Image}"
                                    Stretch="UniformToFill"
                                    IsVisible="{Binding IsSelected}" />
                                <i:Interaction.Behaviors>
                                    <ia:EventTriggerBehavior EventName="PointerPressed">
                                        <ia:InvokeCommandAction Command="{Binding $parent[UserControl].DataContext.SelectedHeroCommand}" CommandParameter="{Binding}" />
                                    </ia:EventTriggerBehavior>
                                </i:Interaction.Behaviors>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Grid Grid.Column="1" Margin="80,100,80,120">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="0.2*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="0.5*" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Vertical">
                            <TextBlock
                                FontSize="25"
                                Foreground="White"
                                Text="首选英雄 "/>
                            <Grid Margin="0,20,0,0">
                                <Image
                                    Source="{Binding FirstHeroAvatar, Mode=OneWay}"
                                    Stretch="Uniform" />
                                <Image
                                    Width="20"
                                    Height="20"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    ZIndex="1"
                                    Source="{StaticResource ModeSelectionIcon7Image}"
                                    Stretch="UniformToFill"
                                    IsVisible="{Binding FirstHeroIsNull, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                    <i:Interaction.Behaviors>
                                        <ia:EventTriggerBehavior EventName="PointerPressed">
                                            <ia:InvokeCommandAction Command="{Binding RemoveFirstHeroCommand}" />
                                        </ia:EventTriggerBehavior>
                                    </i:Interaction.Behaviors>
                                </Image>
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Vertical">
                            <TextBlock
                                FontSize="25"
                                Foreground="White"
                                Text="次选英雄 "/>
                            <Grid Margin="0,20,0,0">
                                <Image
                                    Source="{Binding SecondHeroAvatar, Mode=OneWay}"
                                    Stretch="Uniform" />
                                <Image
                                    Width="20"
                                    Height="20"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    ZIndex="1"
                                    Source="{StaticResource ModeSelectionIcon7Image}"
                                    Stretch="UniformToFill"
                                    IsVisible="{Binding SecondHeroIsNull, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                    <i:Interaction.Behaviors>
                                        <ia:EventTriggerBehavior EventName="PointerPressed">
                                            <ia:InvokeCommandAction Command="{Binding RemoveSecondHeroCommand}" />
                                        </ia:EventTriggerBehavior>
                                    </i:Interaction.Behaviors>
                                </Image>
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="5" Orientation="Vertical">
                            <TextBlock
                                FontSize="25"
                                Foreground="White"
                                Text="" />
                            <Grid Margin="0,20,0,0">
                                <Image
                                    Source="{Binding ThirdHeroAvatar, Mode=OneWay}"
                                    Stretch="Uniform" />
                                <Image
                                    Width="20"
                                    Height="20"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    ZIndex="1"
                                    Source="{StaticResource ModeSelectionIcon7Image}"
                                    Stretch="UniformToFill"
                                    IsVisible="{Binding ThirdHeroIsNull, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                    <i:Interaction.Behaviors>
                                        <ia:EventTriggerBehavior EventName="PointerPressed">
                                            <ia:InvokeCommandAction Command="{Binding RemoveThirdHeroCommand}" />
                                        </ia:EventTriggerBehavior>
                                    </i:Interaction.Behaviors>
                                </Image>
                            </Grid>
                        </StackPanel>
                    </Grid>
                    <UniformGrid Grid.Row="1" Columns="2">
                        <Button
                            Height="30"
                            Margin="0,0,30,0"
                            Command="{Binding SaveCommand}"
                            Content="确定" />
                        <Button
                            Height="30"
                            Margin="30,0,0,0"
                            Command="{Binding ClearCommand}"
                            Content="一键清空" />
                    </UniformGrid>
                </Grid>
            </Grid>
        </Grid>
        <controls:EscBackControl
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Command="{Binding ReturnCommand}" />
    </Grid>
</bases:UserControlBase>
