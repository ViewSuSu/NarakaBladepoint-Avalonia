<base:UserControlBase
    x:Class="NarakaBladepoint.Modules.PersonalInformation.UI.HistoryMatchRecord.Views.HistoryMatchRecordPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="clr-namespace:NarakaBladepoint.Framework.Core.Bases.Views;assembly=NarakaBladepoint.Framework"
    xmlns:controls="clr-namespace:NarakaBladepoint.Controls;assembly=NarakaBladepoint.Controls"
    xmlns:converters="clr-namespace:NarakaBladepoint.Modules.PersonalInformation.UI.HistoryMatchRecord.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels1="clr-namespace:NarakaBladepoint.Modules.PersonalInformation.UI.HistoryMatchRecord.ViewModels"
    d:DesignHeight="720"
    d:DesignWidth="1280"
    xmlns:i="using:Avalonia.Xaml.Interactivity"
    xmlns:ia="using:Avalonia.Xaml.Interactions.Core"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BoolToAddOrDeleteConverter x:Key="BoolToAddOrDeleteConverter" />
        
    </UserControl.Resources>
    <Grid Margin="50,80,50,50">
        <TabControl Background="Transparent" BorderThickness="0">
            <TabItem
                Width="150"
                Background="Transparent"
                BorderThickness="0"
                Header="天选之人">
                <Grid>
                    <ListBox
                        x:Name="listbox"
                        Grid.Row="1"
                        Margin="0,10,0,0"
                        Background="Transparent"
                        BorderThickness="0"
                        ItemsSource="{Binding MatchDataItems, Mode=OneWay}"
                        ScrollViewer.VerticalScrollBarVisibility="Hidden">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <controls:HighlightBorder>
                                    <Grid
                                        Height="50"
                                        Margin="0,5"
                                        Background="#1A000000">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="0.75*" />
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="0.5*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="0.75*" />
                                            <ColumnDefinition Width="0.7*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Grid.Column="0"
                                            BorderBrush="White"
                                            BorderThickness="0.1">
                                            <Image
                                                Width="60"
                                                Source="{Binding Avatar, Mode=OneWay}"
                                                Stretch="Uniform" />
                                        </Border>
                                        <Grid Grid.Column="1" Margin="5,0,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <Image
                                                Height="20"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Source="avares://NarakaBladepoint.Resources/Image/出类拔萃.png"
                                                IsVisible="{Binding IsNo3To4, Mode=OneWay}" />
                                            <Image
                                                Height="20"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Source="avares://NarakaBladepoint.Resources/Image/一人之下.png"
                                                IsVisible="{Binding IsNo2, Mode=OneWay}" />
                                            <Image
                                                Height="20"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Source="avares://NarakaBladepoint.Resources/Image/唯我独尊.png"
                                                IsVisible="{Binding IsNo1, Mode=OneWay}" />
                                            <StackPanel
                                                Grid.Row="1"
                                                Margin="0,5,0,0"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal">
                                                <TextBlock VerticalAlignment="Center" Foreground="White">
                                                    <Run
                                                        Name="CurrentRank"
                                                        Text="{Binding CurrentRank, Mode=OneWay}" />
                                                    <Run Text="/" />
                                                    <Run Text="{Binding AllTeams, Mode=OneWay}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                            <i:Interaction.Behaviors>
                                                <ia:EventTriggerBehavior EventName="PointerPressed">
                                                    <ia:InvokeCommandAction Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl, Mode=FindAncestor}, Path=DataContext.DetailCommand}" CommandParameter="{Binding}" />
                                                </ia:EventTriggerBehavior>
                                            </i:Interaction.Behaviors>
                                        <StackPanel
                                            Grid.Column="2"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <Image
                                                Height="20"
                                                Source="avares://NarakaBladepoint.Resources/Image/击杀数.png"
                                                Stretch="UniformToFill" />
                                            <TextBlock
                                                Margin="5,0,0,0"
                                                VerticalAlignment="Center"
                                                Foreground="White"
                                                Text="{Binding KillNumber, Mode=OneWay}" />
                                        </StackPanel>
                                        <StackPanel
                                            Grid.Column="3"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <Image
                                                Height="20"
                                                Source="avares://NarakaBladepoint.Resources/Image/造成伤害.png"
                                                Stretch="UniformToFill" />
                                            <TextBlock
                                                Margin="5,0,0,0"
                                                VerticalAlignment="Center"
                                                Foreground="White"
                                                Text="{Binding Damage, Mode=OneWay}" />
                                        </StackPanel>
                                        <ItemsControl
                                            Name="itemsControl"
                                            Grid.Column="4"
                                            VerticalAlignment="Center"
                                            ItemsSource="{Binding Achievements, Mode=OneWay}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Image
                                                            Width="20"
                                                            Margin="2,0"
                                                            Source="{Binding}" />
                                                        <Popup />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Grid Grid.Column="5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition Width="30" />
                                            </Grid.ColumnDefinitions>
                                            <UniformGrid
                                                Rows="2"
                                                IsVisible="{Binding IsHightLevel, Mode=OneWay}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="15"
                                                        Foreground="White"
                                                        Text="无相龙王" />
                                                    <Image
                                                        Width="20"
                                                        Margin="5,0,0,0"
                                                        Source="avares://NarakaBladepoint.Resources/Image/星.png" />
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        Foreground="#FFFFA500"
                                                        Text="15" />
                                                </StackPanel>
                                                <Grid VerticalAlignment="Center">
                                                    <ProgressBar
                                                        Height="15"
                                                        Background="Black"
                                                        Foreground="#EAB181"
                                                        Maximum="100"
                                                        Value="40" />
                                                    <TextBlock Margin="5,0,0,0" Foreground="White">
                                                        <Run Text="42" />
                                                        <Run Text="(" />
                                                        <Run Text="12" />
                                                        <Run Text=")" />
                                                    </TextBlock>
                                                </Grid>
                                            </UniformGrid>
                                            <StackPanel
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal">
                                                <TextBlock
                                                    FontSize="15"
                                                    Foreground="White"
                                                    Text="{Binding CurrentLevel, Mode=OneWay}" />
                                                <TextBlock
                                                    Margin="5,0,0,0"
                                                    FontSize="15"
                                                    Foreground="White">
                                                    <Run
                                                        Text="{Binding Score, Mode=OneWay}" />
                                                    <Run Text="(" />
                                                    <Run
                                                        Name="add"
                                                        Text="{Binding IsAdd, Mode=OneWay, Converter={StaticResource BoolToAddOrDeleteConverter}}" />
                                                    <Run
                                                        Text="{Binding ChangeScore, Mode=OneWay}" />
                                                    <Run Text=")" />
                                                </TextBlock>
                                            </StackPanel>
                                            <Image
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Source="avares://NarakaBladepoint.Resources/Image/400+.png"
                                                IsVisible="{Binding IsEasy, Mode=OneWay}" />
                                        </Grid>
                                        <Grid Grid.Column="6" Margin="10,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition Width="30" />
                                            </Grid.ColumnDefinitions>
                                            <UniformGrid Rows="2">
                                                <Grid>
                                                    <TextBlock
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        FontSize="15"
                                                        Foreground="White"
                                                        Text="排位赛三排" />
                                                    <Image
                                                        Width="15"
                                                        HorizontalAlignment="Right"
                                                        Source="avares://NarakaBladepoint.Resources/Image/豪杰对局.png"
                                                        IsVisible="{Binding IsHightLevel, Mode=OneWay}" />
                                                </Grid>
                                                <TextBlock
                                                    Grid.Row="1"
                                                    VerticalAlignment="Center"
                                                    Foreground="#64FFFFFF"
                                                    Text="15:37 2025/12/21" />
                                            </UniformGrid>
                                            <Image
                                                Grid.Column="1"
                                                Width="15"
                                                VerticalAlignment="Center"
                                                Source="avares://NarakaBladepoint.Resources/Image/对局详情.png" />
                                        </Grid>
                                    </Grid>
                                </controls:HighlightBorder>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>
            <TabItem
                Width="150"
                Background="Transparent"
                Header="征神之路">
                <Grid Margin="0,10,0,0" Background="#1A000000">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="20"
                        Text="暂无比赛数据" />
                </Grid>
            </TabItem>
            <TabItem
                Width="150"
                Background="Transparent"
                Header="无间镖客">
                <Grid Margin="0,10,0,0" Background="#1A000000">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="20"
                        Text="暂无比赛数据" />
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</base:UserControlBase>