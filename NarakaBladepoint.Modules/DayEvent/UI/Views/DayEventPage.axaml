<bases:UserControlBase
    x:Class="NarakaBladepoint.Modules.DayEvent.UI.Views.DayEventPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:attach="clr-namespace:NarakaBladepoint.Framework.UI.AttachedProperties;assembly=NarakaBladepoint.Framework"
    xmlns:bases="clr-namespace:NarakaBladepoint.Framework.Core.Bases.Views;assembly=NarakaBladepoint.Framework"
    xmlns:controls="clr-namespace:NarakaBladepoint.Controls;assembly=NarakaBladepoint.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:NarakaBladepoint.Modules.DayEvent.UI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:NarakaBladepoint.Modules.DayEvent.UI.ViewModels"
    d:DesignHeight="330"
    d:DesignWidth="240"
    xmlns:i="using:Avalonia.Xaml.Interactivity"
    xmlns:ia="using:Avalonia.Xaml.Interactions.Core"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.2*" />
            <RowDefinition Height="0.75*" />
            <RowDefinition />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#5A000000">
            <Grid>
                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                    <Image
                        Height="20"
                        Source="{StaticResource DailyTaskFlowerImage}"
                        Stretch="Uniform" />
                    <TextBlock
                        Margin="5,0,0,0"
                        VerticalAlignment="Center"
                        Foreground="White"
                        Text="每日任务" />
                </StackPanel>
                <Border
                    Width="60"
                    HorizontalAlignment="Right"
                    Background="#5A000000">
                    <Image Source="{StaticResource TaskDetailsImage}" Stretch="Uniform">
                        <i:Interaction.Behaviors>
                            <ia:EventTriggerBehavior EventName="PointerPressed">
                                <ia:InvokeCommandAction Command="{Binding TaskDetailsComamnd}" />
                            </ia:EventTriggerBehavior>
                        </i:Interaction.Behaviors>
                    </Image>
                </Border>
            </Grid>
        </Border>
        <Border Grid.Row="1" Margin="0,5">
            <Border.Background>
                <ImageBrush Source="{StaticResource DailyTaskBackground1Image}" Stretch="UniformToFill" />
            </Border.Background>
            <controls:HighlightBorder Height="80" HorizontalAlignment="Right">
                <Image Source="{StaticResource DailyTaskRewardImage}" Stretch="Uniform" />
            </controls:HighlightBorder>
        </Border>
        <UniformGrid
            Grid.Row="2"
            Margin="0,1"
            Background="#5A000000"
            Rows="3">
            <controls:HighlightBorder>
                <TextBlock
                    Margin="10,0"
                    VerticalAlignment="Center"
                    attach:TextBlockHighlightAttachedProperty.HighlightText="2"
                    Foreground="White"
                    Text="完成任意2场对局" />
            </controls:HighlightBorder>
            <controls:HighlightBorder>
                <TextBlock
                    Margin="10,0"
                    VerticalAlignment="Center"
                    attach:TextBlockHighlightAttachedProperty.HighlightText="2000"
                    Foreground="White"
                    Text="累计使用近战武器造成2000点伤害 "/>
            </controls:HighlightBorder>
            <controls:HighlightBorder>
                <TextBlock
                    Margin="10,0"
                    VerticalAlignment="Center"
                    attach:TextBlockHighlightAttachedProperty.HighlightText="2000"
                    Foreground="White"
                    Text="累计移动2000米 "/>
            </controls:HighlightBorder>
        </UniformGrid>
        <Border
            Grid.Row="3"
            Margin="0,5"
            Background="#5A000000">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.25*" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Button
                    Content="聚宝阁"
                    FontSize="9" />
                <controls:HighlightBorder Grid.Row="1">
                    <Image Source="{StaticResource TreasurePavilionImage}" Stretch="Fill" />
                </controls:HighlightBorder>
            </Grid>
        </Border>
    </Grid>
</bases:UserControlBase>
